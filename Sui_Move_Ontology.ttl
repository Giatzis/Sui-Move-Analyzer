sui:specifies a owl:ObjectProperty ;
    rdfs:label "specifies" .

sui:verifies a owl:ObjectProperty ;
    rdfs:label "verifies" .

sui:hasClause a owl:ObjectProperty ;
    rdfs:label "has clause" ;
