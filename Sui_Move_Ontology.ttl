# ============================================================================
# LAYER 2: SECURITY LAYER - VULNERABILITY DEFECTS
# ============================================================================

suwc:VulnerabilityCategory a owl:Class ;
    rdfs:label "Vulnerability Category" ;
    rdfs:comment "Layer 2: Sui Move security vulnerability taxonomy (SUWC)" .

# SUWC-AUTH: Authorization Defects (4 defects)
suwc:SUWC-AUTH a owl:Class ;
    rdfs:label "SUWC-AUTH" ;
    rdfs:label "Authorization Defects" ;
    rdfs:subClassOf suwc:VulnerabilityCategory ;
    rdfs:comment "Authorization and access control vulnerabilities" .

suwc:SUWC-AUTH-01 a owl:Class ;
    rdfs:label "SUWC-AUTH-01" ;
    rdfs:label "Missing Signer Check" ;
    rdfs:subClassOf suwc:SUWC-AUTH ;
    rdfs:comment "Function lacks required signer verification" ;
    rdfs:comment "Severity: CRITICAL" .

suwc:SUWC-AUTH-02 a owl:Class ;
    rdfs:label "SUWC-AUTH-02" ;
    rdfs:label "Capability Leakage" ;
    rdfs:subClassOf suwc:SUWC-AUTH ;
    rdfs:comment "AdminCap with store/copy ability leaked to unauthorized users" ;
    rdfs:comment "Severity: CRITICAL" .

suwc:SUWC-AUTH-03 a owl:Class ;
    rdfs:label "SUWC-AUTH-03" ;
    rdfs:label "Witness Pattern Violation" ;
    rdfs:subClassOf suwc:SUWC-AUTH ;
    rdfs:comment "One-Time Witness (OTW) struct borrowed instead of consumed" ;
    rdfs:comment "Severity: HIGH" .

suwc:SUWC-AUTH-04 a owl:Class ;
    rdfs:label "SUWC-AUTH-04" ;
    rdfs:label "Shared Object Permission Bypass" ;
    rdfs:subClassOf suwc:SUWC-AUTH ;
    rdfs:comment "Authorization check on shared object ignored" ;
    rdfs:comment "Severity: CRITICAL" .

# SUWC-TIME: Temporal Correctness Defects (4 defects)
suwc:SUWC-TIME a owl:Class ;
    rdfs:label "SUWC-TIME" ;
    rdfs:label "Temporal Correctness Defects" ;
    rdfs:subClassOf suwc:VulnerabilityCategory ;
    rdfs:comment "Time-based vulnerabilities and temporal logic errors" .

suwc:SUWC-TIME-01 a owl:Class ;
    rdfs:label "SUWC-TIME-01" ;
    rdfs:label "Premature Release" ;
    rdfs:subClassOf suwc:SUWC-TIME ;
    rdfs:comment "Time-locked assets released before vesting period elapses" ;
    rdfs:comment "Severity: CRITICAL" .

suwc:SUWC-TIME-02 a owl:Class ;
    rdfs:label "SUWC-TIME-02" ;
    rdfs:label "Indefinite Lock" ;
    rdfs:subClassOf suwc:SUWC-TIME ;
    rdfs:comment "Assets locked with impossible or missing extraction conditions" ;
    rdfs:comment "Severity: HIGH" .

suwc:SUWC-TIME-03 a owl:Class ;
    rdfs:label "SUWC-TIME-03" ;
    rdfs:label "Timestamp Manipulation" ;
    rdfs:subClassOf suwc:SUWC-TIME ;
    rdfs:comment "Relying on timestamp_ms instead of epoch for time-critical logic" ;
    rdfs:comment "Severity: HIGH" .

suwc:SUWC-TIME-04 a owl:Class ;
    rdfs:label "SUWC-TIME-04" ;
    rdfs:label "Race Between Time Conditions" ;
    rdfs:subClassOf suwc:SUWC-TIME ;
    rdfs:comment "Multiple transactions race on shared vesting/staking pool at epoch boundaries" ;
    rdfs:comment "Severity: MEDIUM" .

# SUWC-RES: Resource Management Defects (3 defects) - PRESERVED FROM V3.4
suwc:SUWC-RES a owl:Class ;
    rdfs:label "SUWC-RES" ;
    rdfs:label "Resource Management Defects" ;
    rdfs:subClassOf suwc:VulnerabilityCategory ;
    rdfs:comment "Resource and asset management vulnerabilities" .

suwc:SUWC-RES-01 a owl:Class ;
    rdfs:label "SUWC-RES-01" ;
    rdfs:label "Hot Potato Drop" ;
    rdfs:subClassOf suwc:SUWC-RES ;
    rdfs:comment "Receipt struct with drop ability bypasses forced execution obligation" ;
    rdfs:comment "Severity: HIGH" .

suwc:SUWC-RES-02 a owl:Class ;
    rdfs:label "SUWC-RES-02" ;
    rdfs:label "Object Locking / Roach Motel" ;
    rdfs:subClassOf suwc:SUWC-RES ;
    rdfs:comment "Object wrapped permanently with no extraction mechanism" ;
    rdfs:comment "Severity: CRITICAL" .

suwc:SUWC-RES-03 a owl:Class ;
    rdfs:label "SUWC-RES-03" ;
    rdfs:label "Permanent Locking" ;
    rdfs:subClassOf suwc:SUWC-RES ;
    rdfs:comment "No way to extract assets from locked state" ;
    rdfs:comment "Severity: CRITICAL" .

# SUWC-CONS: Consensus/Concurrency Defects (2 defects) - PRESERVED FROM V3.4
suwc:SUWC-CONS a owl:Class ;
    rdfs:label "SUWC-CONS" ;
    rdfs:label "Consensus/Concurrency Defects" ;
    rdfs:subClassOf suwc:VulnerabilityCategory ;
    rdfs:comment "Consensus and concurrency vulnerabilities" .

suwc:SUWC-CONS-01 a owl:Class ;
    rdfs:label "SUWC-CONS-01" ;
    rdfs:label "Curve Invariant Violation" ;
    rdfs:subClassOf suwc:SUWC-CONS ;
    rdfs:comment "Mathematical invariant (e.g., x*y=k in AMM) breaks after state change" ;
    rdfs:comment "Severity: HIGH" .

suwc:SUWC-CONS-02 a owl:Class ;
    rdfs:label "SUWC-CONS-02" ;
    rdfs:label "Vector-Based Denial of Service" ;
    rdfs:subClassOf suwc:SUWC-CONS ;
    rdfs:comment "Unbounded iteration over collections causes gas exhaustion" ;
    rdfs:comment "Severity: CRITICAL" .

# ============================================================================
# LAYER 3: BUSINESS LOGIC PATTERNS
# ============================================================================

pattern:BusinessLogicPattern a owl:Class ;
    rdfs:label "Business Logic Pattern" ;
    rdfs:comment "Layer 3: Architectural patterns that address security defects" ;
    dcterms:date "2026-01-06"^^xsd:date .

pattern:AccessControlPattern a owl:Class ;
    rdfs:label "AccessControlPattern" ;
    rdfs:subClassOf pattern:BusinessLogicPattern ;
    rdfs:comment "Addresses authorization vulnerabilities using capability-based access control" ;
    sui:addressesDefect suwc:SUWC-AUTH-01 ;
    sui:addressesDefect suwc:SUWC-AUTH-02 ;
    sui:addressesDefect suwc:SUWC-AUTH-03 ;
    sui:addressesDefect suwc:SUWC-AUTH-04 .

pattern:CircuitBreakerPattern a owl:Class ;
    rdfs:label "CircuitBreakerPattern" ;
    rdfs:subClassOf pattern:BusinessLogicPattern ;
    rdfs:comment "Mitigates consensus and mathematical vulnerabilities with pausable operations" ;
    sui:addressesDefect suwc:SUWC-CONS-01 ;
    sui:addressesDefect suwc:SUWC-CONS-02 .

pattern:TimeIncentivizationPattern a owl:Class ;
    rdfs:label "TimeIncentivizationPattern" ;
    rdfs:subClassOf pattern:BusinessLogicPattern ;
    rdfs:comment "Prevents temporal correctness vulnerabilities with epoch-based time locking" ;
    sui:addressesDefect suwc:SUWC-TIME-01 ;
    sui:addressesDefect suwc:SUWC-TIME-02 ;
    sui:addressesDefect suwc:SUWC-TIME-03 ;
    sui:addressesDefect suwc:SUWC-TIME-04 .

pattern:EscapabilityPattern a owl:Class ;
    rdfs:label "EscapabilityPattern" ;
    rdfs:subClassOf pattern:BusinessLogicPattern ;
    rdfs:comment "Ensures asset extraction and escape from locked states with upgrade mechanisms" ;
    sui:addressesDefect suwc:SUWC-RES-01 ;
    sui:addressesDefect suwc:SUWC-RES-02 ;
    sui:addressesDefect suwc:SUWC-RES-03 ;
    sui:addressesDefect suwc:SUWC-AUTH-03 ;
    sui:addressesDefect suwc:SUWC-TIME-04 .

# ============================================================================
# LAYER 3B: IMPLEMENTATION TECHNIQUE LAYER (PhD Defense Addition)
# Added: February 16, 2026
# Purpose: Encode the "why vs. how" distinction described in Chapter 5:
#   WHY = pattern:BusinessLogicPattern (abstract security intent)
#   HOW = sui:SuiImplementationPattern (idiomatic Sui Move technique)
# Three-step semantic chain:
#   AbstractPattern --isImplementedBy--> Technique --usesTechnique<-- Code
# ============================================================================

sui:SuiImplementationPattern a owl:Class ;
    rdfs:label "Sui Implementation Pattern" ;
    rdfs:subClassOf sui:BusinessLogicLayer ;
    rdfs:comment "Low-level, idiomatic Sui Move technique that realizes an abstract security pattern" ;
    dcterms:date "2026-02-16"^^xsd:date .
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AccessControlPattern Techniques
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:CapabilityTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Capability Technique" ;
    rdfs:comment "Access control via capability structs (AdminCap, OwnerCap, TreasuryCap) with key ability" ;
    sui:realizesPattern pattern:AccessControlPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

sui:WitnessTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Witness Technique" ;
    rdfs:comment "Type-safe authorization via One-Time Witness (OTW) pattern for init-time operations" ;
    sui:realizesPattern pattern:AccessControlPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

sui:DynamicACLTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Dynamic ACL Technique" ;
    rdfs:comment "Role-based access via Table<address> or VecSet<address> membership lookups" ;
    sui:realizesPattern pattern:AccessControlPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CircuitBreakerPattern Techniques
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:AdminStateControlTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Admin State Control Technique" ;
    rdfs:comment "Emergency pause via PauseCap/EmergencyCap + boolean paused state field" ;
    sui:realizesPattern pattern:CircuitBreakerPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TimeIncentivizationPattern Techniques
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:EpochTimeLockTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Epoch Time Lock Technique" ;
    rdfs:comment "Temporal constraints via Clock object + epoch/timestamp_ms comparisons with assert!" ;
    sui:realizesPattern pattern:TimeIncentivizationPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EscapabilityPattern Techniques
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:UpgradeCapTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Upgrade Cap Technique" ;
    rdfs:comment "Protocol migration via UpgradeCap/UpgradeTicket/UpgradeReceipt/MigrationCap" ;
    sui:realizesPattern pattern:EscapabilityPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

sui:DynamicFieldExtractionTechnique a sui:SuiImplementationPattern, owl:NamedIndividual ;
    rdfs:label "Dynamic Field Extraction Technique" ;
    rdfs:comment "Asset extraction from locked state via dynamic_field::remove and option::extract" ;
    sui:realizesPattern pattern:EscapabilityPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

# ============================================================================
# DCR EVENT CLASSES (Behavioral Layer)
# ============================================================================

pattern:AC_GrantRole a owl:Class ;
    rdfs:label "AC_GrantRole" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Grant Role (Condition) - Creates capability for access control" .

pattern:AC_ProtectedCall a owl:Class ;
    rdfs:label "AC_ProtectedCall" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Protected Call (Response) - Executes protected operation requiring capability" .

pattern:AC_RevokeRole a owl:Class ;
    rdfs:label "AC_RevokeRole" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Revoke Role (Exclusion) - Destroys capability to revoke access" .

pattern:TI_Start a owl:Class ;
    rdfs:label "TI_Start" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Time Start (Condition) - Initiates time-locked operation with Clock parameter" .

pattern:TI_Proceed a owl:Class ;
    rdfs:label "TI_Proceed" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Proceed (Response) - Executes time-dependent action after time constraint satisfied" .

pattern:CB_Pause a owl:Class ;
    rdfs:label "CB_Pause" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Pause System (Exclusion) - Emergency pause that excludes normal operations" .

pattern:CB_Unpause a owl:Class ;
    rdfs:label "CB_Unpause" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Unpause System (Inclusion) - Re-enables paused operations" .

pattern:ES_Authorize a owl:Class ;
    rdfs:label "ES_Authorize" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Authorize Upgrade (Condition) - Authorizes protocol upgrade or migration" .

pattern:ES_Escape a owl:Class ;
    rdfs:label "ES_Escape" ;
    rdfs:subClassOf dcr:Event ;
    rdfs:comment "DCR Event: Commit Escape (Response) - Executes escape/upgrade after authorization" .


# ============================================================================
# PROPERTY DEFINITIONS FOR PATTERNS AND DEFECTS
# ============================================================================

sui:addressesDefect a owl:ObjectProperty ;
    rdfs:label "addresses defect" ;
    rdfs:comment "BusinessLogicPattern prescriptively prevents/remediates this defect" ;
    rdfs:domain pattern:BusinessLogicPattern ;
    rdfs:range suwc:VulnerabilityCategory .

sui:indicatesDefectRisk a owl:ObjectProperty ;
    rdfs:label "indicates defect risk" ;
    rdfs:comment "SecurityOperation whose presence without an authorization guard signals risk of this defect — diagnostic detection trigger" ;
    rdfs:domain sui:SecurityOperation ;
    rdfs:range suwc:VulnerabilityCategory .

sui:mitigatesDefect a owl:ObjectProperty ;
    rdfs:label "mitigates defect" ;
    rdfs:comment "SecurityOperation whose presence indicates the defect is being handled — its absence signals vulnerability" ;
    rdfs:domain sui:SecurityOperation ;
    rdfs:range suwc:VulnerabilityCategory .

sui:isAddressedBy a owl:ObjectProperty ;
    rdfs:label "is addressed by" ;
    rdfs:comment "Defect is addressed by a specific pattern" ;
    owl:inverseOf sui:addressesDefect ;
    rdfs:domain suwc:VulnerabilityCategory ;
    rdfs:range pattern:BusinessLogicPattern .

sui:formalizes a owl:ObjectProperty ;
    rdfs:label "formalizes" ;
    rdfs:comment "Pattern is formalized as a DCR process" ;
    rdfs:domain pattern:BusinessLogicPattern ;
    rdfs:range dcr:Process .

sui:isImplementedBy a owl:ObjectProperty ;
    rdfs:label "is implemented by" ;
    rdfs:comment "Abstract pattern is implemented by a Sui Move implementation technique" ;
    rdfs:domain pattern:BusinessLogicPattern ;
    rdfs:range sui:SuiImplementationPattern .

sui:realizesPattern a owl:ObjectProperty ;
    rdfs:label "realizes pattern" ;
    rdfs:comment "Implementation technique realizes an abstract security pattern" ;
    rdfs:domain sui:SuiImplementationPattern ;
    rdfs:range pattern:BusinessLogicPattern ;
    owl:inverseOf sui:isImplementedBy ;
    dcterms:date "2026-02-16"^^xsd:date .

sui:usesTechnique a owl:ObjectProperty ;
    rdfs:label "uses technique" ;
    rdfs:comment "Code element uses a specific Sui Move implementation technique" ;
    rdfs:domain [ a owl:Class; owl:unionOf (sui:Module sui:Function) ] ;
    rdfs:range sui:SuiImplementationPattern ;
    dcterms:date "2026-02-16"^^xsd:date .

sui:implementsPattern a owl:ObjectProperty ;
    rdfs:label "implements pattern" ;
    rdfs:comment "Link code to business logic pattern" ;
    rdfs:domain [ a owl:Class; owl:unionOf (sui:Module sui:Struct sui:Function) ] ;
    rdfs:range pattern:BusinessLogicPattern .

# ============================================================================
# LAYER 4: FORMAL LAYER - OC-DCR (OBJECT-CENTRIC DCR)
# ============================================================================

dcr:Process a owl:Class ;
    rdfs:label "DCR Process" ;
    rdfs:comment "Layer 4: Formal process definition in DCR graph semantics" .

dcr:Event a owl:Class ;
    rdfs:label "DCR Event" ;
    rdfs:comment "Event in a DCR process" .

dcr:condition a owl:ObjectProperty ;
    rdfs:label "DCR Condition Relation" ;
    rdfs:comment "Condition relation between DCR events" .

dcr:response a owl:ObjectProperty ;
    rdfs:label "DCR Response Relation" ;
    rdfs:comment "Response relation between DCR events" .

dcr:inclusion a owl:ObjectProperty ;
    rdfs:label "DCR Inclusion Relation" ;
    rdfs:comment "Inclusion relation in DCR" .

dcr:exclusion a owl:ObjectProperty ;
    rdfs:label "DCR Exclusion Relation" ;
    rdfs:comment "Exclusion relation in DCR" .

# Object-Centric DCR (OC-DCR) Extensions
ocdcr:hasEvent a owl:ObjectProperty ;
    rdfs:label "OC-DCR Has Event" ;
    rdfs:domain dcr:Process ;
    rdfs:range dcr:Event ;
    rdfs:comment "OC-DCR process has event" .

ocdcr:involvesEntity a owl:ObjectProperty ;
    rdfs:label "OC-DCR Involves Entity" ;
    rdfs:comment "DCR event involves object-centric entity" .

# Connections between Semantic Layer and Formal Layer
sui:definesLifecycleOf a owl:ObjectProperty ;
    rdfs:label "defines lifecycle of" ;
    rdfs:domain dcr:Process ;
    rdfs:range sui:Struct ;
    rdfs:comment "Links a DCR process to the Struct whose lifecycle it defines" .

sui:spawns a owl:ObjectProperty ;
    rdfs:label "spawns" ;
    rdfs:domain dcr:Event ;
    rdfs:range dcr:Process ;
    rdfs:comment "Event spawns new process instance" .

sui:mapsToFunction a owl:ObjectProperty ;
    rdfs:label "maps to function" ;
    rdfs:domain dcr:Event ;
    rdfs:range sui:Function ;
    rdfs:comment "Maps a DCR event to its corresponding Sui Move function" .

sui:preventsDefect a owl:ObjectProperty ;
    rdfs:label "prevents defect" ;
    rdfs:domain dcr:Event ;
    rdfs:range suwc:VulnerabilityCategory ;
    rdfs:comment "DCR prevention event prevents a specific vulnerability defect" .

sui:exemplifiesDefect a owl:ObjectProperty ;
    rdfs:label "exemplifies defect" ;
    rdfs:domain dcr:Process ;
    rdfs:range suwc:VulnerabilityCategory ;
    rdfs:comment "Attack/violation process exemplifies how a defect manifests" .

sui:blockedBy a owl:ObjectProperty ;
    rdfs:label "blocked by" ;
    rdfs:domain dcr:Process ;
    rdfs:range dcr:Process ;
    rdfs:comment "Attack/violation process is prevented/blocked by pattern process" .

# ============================================================================
# LAYER 3 EXTENSION: SEMANTIC OPERATION DETECTION
# Added: January 10, 2026
# Purpose: Enable semantic detection of security-critical operations for all 4 patterns
# ===========================================================================

sui:BusinessLogicLayer a owl:Class ;
    rdfs:label "Business Logic Layer" ;
    rdfs:comment "Layer 3: Dual-layer model linking abstract security goals (BusinessLogicPattern) to idiomatic Sui Move implementation techniques (SuiImplementationPattern)" ;
    dcterms:date "2026-04-24"^^xsd:date .

# Semantic Operation Class
sui:SecurityOperation a owl:Class ;
    rdfs:label "Security Operation" ;
    rdfs:subClassOf sui:BusinessLogicLayer ;
    rdfs:comment "Security-critical operations" ;
    dcterms:date "2026-01-10"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PATTERN 1: AccessControlPattern Operations
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:BalanceOperation a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Balance Operation" ;
    rdfs:comment "Coin/balance manipulation operation (coin::take, coin::split, coin::join)" ;
    sui:indicatesDefectRisk suwc:SUWC-AUTH-01 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:OwnershipTransfer a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Ownership Transfer" ;
    rdfs:comment "Object ownership change operation (transfer::transfer, transfer::share_object)" ;
    sui:indicatesDefectRisk suwc:SUWC-AUTH-02 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:ObjectCreation a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Object Creation" ;
    rdfs:comment "Object minting/creation operation (coin::mint, ::new)" ;
    sui:indicatesDefectRisk suwc:SUWC-AUTH-03 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:ObjectDeletion a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Object Deletion" ;
    rdfs:comment "Object destruction/burning operation (coin::burn, object::delete)" ;
    sui:indicatesDefectRisk suwc:SUWC-AUTH-04 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:BalanceMutation a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Balance Mutation" ;
    rdfs:comment "Mutable balance reference operation (&mut Balance, &mut Coin)" ;
    sui:indicatesDefectRisk suwc:SUWC-AUTH-01 ;
    dcterms:date "2026-01-10"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PATTERN 2: CircuitBreakerPattern Operations
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:SharedStateMutation a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Shared State Mutation" ;
    rdfs:comment "Mutation of shared object state that could break invariants" ;
    sui:indicatesDefectRisk suwc:SUWC-CONS-01 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:InvariantCheck a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Invariant Check" ;
    rdfs:comment "Mathematical invariant verification (assert! with invariant keyword)" ;
    sui:mitigatesDefect suwc:SUWC-CONS-01 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:UnboundedIteration a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Unbounded Iteration" ;
    rdfs:comment "Unbounded loop or vector iteration creating DoS risk" ;
    sui:indicatesDefectRisk suwc:SUWC-CONS-02 ;
    dcterms:date "2026-01-10"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PATTERN 3: TimeIncentivizationPattern Operations
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:TemporalCheck a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Temporal Check" ;
    rdfs:comment "Clock or epoch timestamp usage (clock::timestamp_ms, tx_context::epoch)" ;
    sui:indicatesDefectRisk suwc:SUWC-TIME-03 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:TemporalConstraint a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Temporal Constraint" ;
    rdfs:comment "Epoch-based temporal constraint (assert! with epoch comparison)" ;
    sui:mitigatesDefect suwc:SUWC-TIME-01 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:TimestampComparison a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Timestamp Comparison" ;
    rdfs:comment "Timestamp comparison in conditional logic" ;
    sui:indicatesDefectRisk suwc:SUWC-TIME-04 ;
    dcterms:date "2026-01-10"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PATTERN 4: EscapabilityPattern Operations
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:DynamicFieldOperation a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Dynamic Field Operation" ;
    rdfs:comment "Dynamic field manipulation (dynamic_field::add, dynamic_field::remove)" ;
    sui:mitigatesDefect suwc:SUWC-RES-02 ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:OptionalExtraction a sui:SecurityOperation, owl:NamedIndividual ;
    rdfs:label "Optional Extraction" ;
    rdfs:comment "Asset extraction from optional wrapper (option::extract, option::swap)" ;
    sui:mitigatesDefect suwc:SUWC-RES-03 ;
    dcterms:date "2026-01-10"^^xsd:date .

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Properties for Semantic Detection
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sui:performsOperation a owl:ObjectProperty ;
    rdfs:label "performs operation" ;
    rdfs:comment "Function performs this security-critical operation (semantic detection)" ;
    rdfs:domain sui:Function ;
    rdfs:range sui:SecurityOperation ;
    dcterms:date "2026-01-10"^^xsd:date .

sui:requiresAccessControl a owl:DatatypeProperty ;
    rdfs:label "requires access control" ;
    rdfs:comment "Function requires capability-based access control (derived from semantic analysis)" ;
    rdfs:domain sui:Function ;
    rdfs:range xsd:boolean ;
    dcterms:date "2026-01-10"^^xsd:date .


